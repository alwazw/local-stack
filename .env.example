# ============================================================
# AEF3 - Autonomous Engineer Framework v3
# Single Source of Truth — NON-SENSITIVE CONFIGURATION ONLY
# ============================================================
# SECURITY: No secrets, passwords, or API keys in this file.
# All secrets are in ./secrets/*.txt and mounted via Docker secrets.
# See docker-compose.yml `secrets:` section for the full list.
# ============================================================

# --- Core Settings ---
TZ=America/Toronto
PUID=1000
PGID=1000
DOMAIN=yourdomain.com

# ============================================================
# Ports (sorted by port number)
# ============================================================
PORT_TRAEFIK_HTTP=80
PORT_TRAEFIK_HTTPS=443
PORT_OPENWEBUI=3000
PORT_GITEA=3001
PORT_UPTIME=3002
PORT_GRAFANA=3000
PORT_HOMEPAGE=3004
PORT_LOKI=3100
PORT_LITELLM=4000
PORT_POSTGRES=5432
PORT_N8N=5678
PORT_DOCKGE=5001
PORT_QDRANT=6333
PORT_REDIS=6379
PORT_MCPO=8000
PORT_WOODPECKER=8001
PORT_SEARXNG=8080
PORT_GUACAMOLE=8081
PORT_VAULTWARDEN=8082
PORT_AFFINE=8083
PORT_LOGSEQ=8084
PORT_PLANE=8085
PORT_AGENTZERO=8501
PORT_HERMES=8787
PORT_AUTHENTIK=9000
PORT_PROMETHEUS=9090
PORT_PORTAINER=9443
PORT_OLLAMA=11434
PORT_OMNIROUTE=20128
PORT_AGENTZERO_API=8081

# ============================================================
# Non-sensitive service configuration
# ============================================================

## Postgres
POSTGRES_USER=youruser
POSTGRES_DB=yourdb

## Vaultwarden
VW_DOMAIN=https://vault.yourdomain.com

## Deployment
BRANCH=main
SSH_DEPLOY_HOST=your-host
SSH_DEPLOY_USER=youruser
SSH_DEPLOY_PORT=22

# ============================================================
# SECRETS — Place files in ./secrets/ directory
# The following files must exist (contents are secrets):
#   secrets/cf_api_email.txt       — Cloudflare API email
#   secrets/cf_dns_api_token.txt   — Cloudflare DNS API token (for Traefik)
#   secrets/cf_api_key.txt         — Cloudflare Global API key (backup)
#   secrets/cf_tunnel_token.txt    — Cloudflare Tunnel token
#   secrets/authentik_secret.txt   — Authentik secret key
#   secrets/hermes_password.txt    — Hermes WebUI password
#   secrets/github_token.txt       — GitHub personal access token
#   secrets/agent_zero_key.txt     — Agent Zero API key
#   secrets/gitea_secret.txt       — Gitea secret key
#   secrets/guac_admin_pass.txt    — Guacamole admin password
#   secrets/litellm_key.txt        — LiteLLM master key
#   secrets/n8n_key.txt            — n8n encryption key
#   secrets/open_web_ui.txt        — Open WebUI secret key
#   secrets/vw_admin_token.txt     — Vaultwarden admin token
#   secrets/postgres_password.txt  — PostgreSQL password
#   secrets/redis_password.txt     — Redis password
#   secrets/ssh_deploy_key         — SSH deploy key (private)
#   secrets/ssh_deploy_key.pub     — SSH deploy key (public)
# ============================================================
