# ============================================================
# AEF3 - Autonomous Engineer Framework v3
# Single Source of Truth — NON-SENSITIVE CONFIGURATION ONLY
# ============================================================
#
# SECURITY BOUNDARY
#   - This file:  non-sensitive configuration ONLY (ports, usernames, paths)
#   - secrets/*:  passwords, tokens, keys, API credentials
#   - NO secrets, passwords, or API keys belong in this file.
#
# HOW TO USE
#   1. Copy this file:  cp .env.example .env
#   2. Edit values in .env (never commit .env)
#   3. Create secret files listed in the SECRETS section below
#
# PROFILE ACTIVATION
#   Services are grouped by profile. Only "core" services start by default.
#   All other groups must be activated explicitly:
#
#     docker compose --profile ai up -d                  # AI/ML stack
#     docker compose --profile network up -d             # Cloudflare tunnel
#     docker compose --profile security up -d            # Authentik + Vaultwarden
#     docker compose --profile monitoring up -d          # Prometheus, Grafana, Loki, etc.
#     docker compose --profile productivity up -d        # Guacamole remote desktop
#     docker compose --profile ci up -d                  # Gitea + n8n
#     docker compose --profile management up -d          # Portainer, Dockge, Homepage
#
#     docker compose --profile ai --profile monitoring up -d  # multiple groups
#     docker compose --profile ai up -d                      # ai only
#
#   No profile (core services — always running):
#     postgres, redis
#
# ============================================================

# ============================================================
# Core Settings
# ============================================================
TZ=America/Toronto
PUID=1000
PGID=1000
DOMAIN=yourdomain.com

# ============================================================
# Ports — all 24 port variables used by the stack
# ============================================================
# Format: PORT_<SERVICE>=<host_port>  (maps to container's internal port)
# All ports bind to 127.0.0.1 unless noted (Traefik binds 0.0.0.0).

## Network
PORT_TRAEFIK_HTTP=80
PORT_TRAEFIK_HTTPS=443

## AI / ML
PORT_OLLAMA=11434
PORT_OPENWEBUI=3000
PORT_LITELLM=4000
PORT_MCPO=8000
PORT_QDRANT=6333
PORT_AGENTZERO=8501
PORT_AGENTZERO_API=8081
PORT_HERMES=8787
PORT_OMNIROUTE=20128

## Data
PORT_POSTGRES=5432
PORT_REDIS=6379

## Security
PORT_AUTHENTIK=9000
PORT_VAULTWARDEN=8082

## Monitoring
PORT_PROMETHEUS=9090
PORT_GRAFANA=3000
PORT_UPTIME=3002
PORT_LOKI=3100

## CI/CD
PORT_GITEA=3001
PORT_N8N=5678

## Management
PORT_PORTAINER=9443
PORT_DOCKGE=5001
PORT_HOMEPAGE=3004

# ============================================================
# Non-sensitive Service Configuration
# ============================================================

## PostgreSQL
POSTGRES_USER=youruser
POSTGRES_DB=yourdb

## Vaultwarden
VW_DOMAIN=https://vault.yourdomain.com

## Grafana (password is sensitive but passed via env var, not Docker secrets)
GRAFANA_ADMIN_PASSWORD=changeme

## Deployment
BRANCH=main
SSH_DEPLOY_HOST=your-host
SSH_DEPLOY_USER=youruser
SSH_DEPLOY_PORT=22

# ============================================================
# SECRETS — Required files in ./secrets/
# ============================================================
# Every secret listed below must exist as a file before starting services.
# File contents are the raw secret value — no extra whitespace or newlines.
# DO NOT put any of these values in this file or in .env.
#
# Cloudflare (Traefik DNS challenge + Tunnel):
#   secrets/cf_api_email.txt         — Cloudflare account email
#   secrets/cf_dns_api_token.txt     — Cloudflare DNS API token (Traefik ACME)
#   secrets/cf_api_key.txt           — Cloudflare Global API key (backup)
#   secrets/cf_tunnel_token.txt      — Cloudflare Tunnel token
#
# Authentication & SSO:
#   secrets/authentik_secret.txt     — Authentik bootstrap secret key
#   secrets/hermes_password.txt      — Hermes WebUI admin password
#   secrets/guac_admin_pass.txt      — Guacamole admin password
#
# Application secrets:
#   secrets/gitea_secret.txt         — Gitea SECRET_KEY
#   secrets/litellm_key.txt          — LiteLLM master API key
#   secrets/n8n_key.txt              — n8n encryption key (N8N_ENCRYPTION_KEY)
#   secrets/open_web_ui.txt          — OpenWebUI / SearXNG shared secret key
#   secrets/vw_admin_token.txt       — Vaultwarden admin token (ADMIN_TOKEN)
#   secrets/agent_zero_key.txt       — Agent Zero API key
#   secrets/github_token.txt         — GitHub personal access token
#
# Database credentials:
#   secrets/postgres_password.txt    — PostgreSQL password (superuser POSTGRES_USER)
#   secrets/redis_password.txt       — Redis requirepass password
#
# SSH deploy key (no .txt extension):
#   secrets/ssh_deploy_key           — SSH private key for deploy user
#   secrets/ssh_deploy_key.pub       — SSH public key (for reference)
#
# Total: 17 secret files
