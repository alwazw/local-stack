# AEF3 - Autonomous Engineer Framework v3
# Root   docker-compose.yml - orchestrates all services
#        docker compose --profile monitoring up -d
#
# Usage: docker compose up -d (from project root)
#        docker compose down   (tear down all)

#
# This file contains ONLY include directives, secrets, and networks.
# Each service is defined in its own compose file under compose/<category>/<service>/docker-compose.yml

# version: "3.8"


include:
  # Network
  - compose/network/traefik/docker-compose.yml
  - compose/network/cloudflared/docker-compose.yml

  # AI
  - compose/ai/agent-zero/docker-compose.yml
  - compose/ai/litellm/docker-compose.yml
  - compose/ai/mcpo/docker-compose.yml
  - compose/ai/ollama/docker-compose.yml
  - compose/ai/openwebui/docker-compose.yml
  - compose/ai/hermes/docker-compose.yml
  - compose/ai/omniroute/docker-compose.yml
  - compose/ai/qdrant/docker-compose.yml
  - compose/ai/searxng/docker-compose.yml

  # Data
  - compose/data/postgres/docker-compose.yml
  - compose/data/redis/docker-compose.yml

  # Security
  - compose/security/authentik-server/docker-compose.yml
  - compose/security/authentik-worker/docker-compose.yml
  - compose/security/vaultwarden/docker-compose.yml

  # Monitoring
  - compose/monitoring/prometheus/docker-compose.yml
  - compose/monitoring/grafana/docker-compose.yml
  - compose/monitoring/uptime-kuma/docker-compose.yml
  - compose/monitoring/loki/docker-compose.yml
  - compose/monitoring/promtail/docker-compose.yml
  - compose/monitoring/cadvisor/docker-compose.yml
  - compose/monitoring/dozzle/docker-compose.yml

  # Management
  - compose/management/portainer/docker-compose.yml
  - compose/management/dockge/docker-compose.yml
  - compose/management/homepage/docker-compose.yml

  # CI
  - compose/ci/gitea/docker-compose.yml
  - compose/ci/n8n/docker-compose.yml

  # Productivity
  - compose/productivity/guacd/docker-compose.yml
  - compose/productivity/guacamole/docker-compose.yml
  - compose/productivity/affine/docker-compose.yml
  - compose/productivity/plane/docker-compose.yml

# =====================
# Secrets — ALL secrets mounted as files, NEVER in .env or environment variables
# Pattern: file: ${FRAMEWORK_ROOT}/secrets/<name>.txt → mounted at /run/secrets/<name>
# Services read secrets via:
#   - _FILE env var (Postgres, Redis, Vaultwarden, etc.)
#   - Entrypoint wrapper script (Traefik, Cloudflared)
# =====================
secrets:
  # Cloudflare — Traefik DNS challenge + Tunnel
  cf_api_email:
    file: ${FRAMEWORK_ROOT}/secrets/cf_api_email.txt
  cf_dns_api_token:
    file: ${FRAMEWORK_ROOT}/secrets/cf_dns_api_token.txt
  cf_api_key:
    file: ${FRAMEWORK_ROOT}/secrets/cf_api_key.txt
  cf_tunnel_token:
    file: ${FRAMEWORK_ROOT}/secrets/cf_tunnel_token.txt

  # Authentication & API keys
  authentik_secret:
    file: ${FRAMEWORK_ROOT}/secrets/authentik_secret.txt
  hermes_password:
    file: ${FRAMEWORK_ROOT}/secrets/hermes_password.txt
  github_token:
    file: ${FRAMEWORK_ROOT}/secrets/github_token.txt
  agent_zero_key:
    file: ${FRAMEWORK_ROOT}/secrets/agent_zero_key.txt

  # Application secrets
  gitea_secret:
    file: ${FRAMEWORK_ROOT}/secrets/gitea_secret.txt
  guac_admin_pass:
    file: ${FRAMEWORK_ROOT}/secrets/guac_admin_pass.txt
  litellm_key:
    file: ${FRAMEWORK_ROOT}/secrets/litellm_key.txt
  n8n_key:
    file: ${FRAMEWORK_ROOT}/secrets/n8n_key.txt
  webui_secret_key:
    file: ${FRAMEWORK_ROOT}/secrets/open_web_ui.txt
  vw_admin_token:
    file: ${FRAMEWORK_ROOT}/secrets/vw_admin_token.txt

  # Database credentials
  postgres_password:
    file: ${FRAMEWORK_ROOT}/secrets/postgres_password.txt
  redis_password:
    file: ${FRAMEWORK_ROOT}/secrets/redis_password.txt

  # Productivity service secrets
  affine_database_url:
    file: ${FRAMEWORK_ROOT}/secrets/affine_database_url.txt
  plane_database_url:
    file: ${FRAMEWORK_ROOT}/secrets/plane_database_url.txt
  plane_redis_url:
    file: ${FRAMEWORK_ROOT}/secrets/plane_redis_url.txt
  plane_secret_key:
    file: ${FRAMEWORK_ROOT}/secrets/plane_secret_key.txt
  grafana_admin_password:
    file: ${FRAMEWORK_ROOT}/secrets/grafana_admin_password.txt

  # SSH deploy key
  ssh_deploy_key:
    file: ${FRAMEWORK_ROOT}/secrets/ssh_deploy_key

  # External LLM API Keys (for LiteLLM gateway)
  openrouter_key_1:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/openrouter_key_1.txt
  openrouter_key_2:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/openrouter_key_2.txt
  openrouter_key_3:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/openrouter_key_3.txt
  nvidia_nim_key_1:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/nvidia_nim_key_1.txt
  gemini_key_1:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/gemini_key_1.txt
  gemini_key_2:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/gemini_key_2.txt
  gemini_key_3:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/gemini_key_3.txt
  grok_key_1:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/grok_key_1.txt
  alibaba_key_1:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/alibaba_key_1.txt
  alibaba_key_2:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/alibaba_key_2.txt
  novita_key_1:
    file: ${FRAMEWORK_ROOT}/secrets/external_llm_keys/novita_key_1.txt
